        "jsonBody": "={\n  \"post_info\": {\n    \"title\": {{ JSON.stringify($('Edit Fields').item.json.title) }},\n    \"privacy_level\": \"SELF_ONLY\",\n    \"disable_duet\": false,\n    \"disable_comment\": false,\n    \"disable_stitch\": false,\n    \"video_cover_timestamp_ms\": 1000\n  },\n  \"source_info\": {\n    \"source\": \"{{ $json.tiktokInitPayload.source_info.source }}\",\n    \"video_size\": {{ $json.tiktokInitPayload.source_info.video_size }},\n    \"chunk_size\": {{ $json.tiktokInitPayload.source_info.chunk_size }},\n    \"total_chunk_count\": {{ $json.tiktokInitPayload.source_info.total_chunk_count }}\n  }\n}",
