        1056,
        0
      ],
      "id": "5f1f4183-1bef-4812-833a-e37892f540a2",
      "name": "process upload"
    },
    {
      "parameters": {
        "jsCode": "// Ambil binary data dari node sebelumnya (misalnya dari S3/R2)\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\n\n// Konfigurasi\nconst videoSize = buffer.length; // Total ukuran file dalam bytes\n\n// Fungsi untuk menentukan chunk size optimal\nfunction getOptimalChunkSize(fileSize) {\n  const MB = 1024 * 1024;\n  \n  if (fileSize < 50 * MB) {\n    return fileSize; // Upload sekaligus untuk file kecil\n  } else if (fileSize < 500 * MB) {\n    return 10 * MB; // 10MB chunks untuk file sedang\n  } else {\n    return 20 * MB; // 20MB chunks untuk file besar\n  }\n}\n\n// Hitung chunk size dan total chunks\nconst chunkSize = getOptimalChunkSize(videoSize);\nconst totalChunkCount = Math.ceil(videoSize / chunkSize);\n\n// Buat array untuk semua chunks dengan header masing-masing\nconst chunks = [];\nfor (let i = 0; i < totalChunkCount; i++) {\n  const start = i * chunkSize;\n  const end = Math.min(start + chunkSize - 1, videoSize - 1);\n  const currentChunkSize = end - start + 1;\n  \n  chunks.push({\n    chunkIndex: i,\n    start: start,\n    end: end,\n    size: currentChunkSize,\n    contentRange: `bytes ${start}-${end}/${videoSize}`,\n    contentLength: currentChunkSize\n  });\n}\n\n// Return hasil\nreturn [\n  {\n    json: {\n      // Info file\n      videoSize: videoSize,\n      videoSizeMB: (videoSize / 1024 / 1024).toFixed(2),\n      contentType: items[0].binary.data.mimeType || 'video/mp4',\n      \n      // Info chunking\n      chunkSize: chunkSize,\n      chunkSizeMB: (chunkSize / 1024 / 1024).toFixed(2),\n      totalChunkCount: totalChunkCount,\n      \n      // Headers untuk single upload (jika 1 chunk)\n      singleUploadHeaders: {\n        'Content-Type': items[0].binary.data.mimeType || 'video/mp4',\n        'Content-Length': videoSize.toString(),\n        'Content-Range': `bytes 0-${videoSize - 1}/${videoSize}`\n      },\n      \n      // Detail semua chunks (untuk multi-chunk upload)\n      chunks: chunks,\n      \n      // Data untuk TikTok init payload\n      tiktokInitPayload: {\n        source_info: {\n          source: 'FILE_UPLOAD',\n          video_size: videoSize,\n          chunk_size: chunkSize,\n          total_chunk_count: totalChunkCount\n        }\n      }\n    },\n    binary: {\n      data: items[0].binary.data // Pass through binary data\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
