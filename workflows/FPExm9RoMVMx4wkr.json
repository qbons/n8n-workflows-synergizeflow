    {
      "parameters": {
        "jsCode": "// 1. Get the photos from the Telegram Trigger node first\nconst triggerPhotos = $('Telegram Trigger').first().json.message?.photo;\n\nfor (const item of $input.all()) {\n  \n  // 2. Check if we actually found photos\n  if (triggerPhotos && triggerPhotos.length > 0) {\n    \n    // 3. Filter: Try to find photos that fit within 1000x800\n    const validPhotos = triggerPhotos.filter(photo => photo.width <= 1000 && photo.height <= 800);\n\n    let selectedPhoto;\n\n    if (validPhotos.length > 0) {\n      // SCENARIO A: We found valid photos. \n      // Pick the last one (the largest quality that still fits the limit).\n      selectedPhoto = validPhotos.at(-1);\n    } else {\n      // SCENARIO B: All photos are too big.\n      // Fallback to the very first photo (index 0), which is the smallest available version.\n      selectedPhoto = triggerPhotos[0];\n    }\n\n    // 4. Assign to the current item\n    item.json.selected_photo = selectedPhoto;\n    item.json.selected_file_id = selectedPhoto.file_id;\n\n  } else {\n    // Logic if no photos were found in the trigger at all\n    item.json.selected_photo = null;\n    item.json.selected_file_id = null;\n  }\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3728,
        160
      ],
