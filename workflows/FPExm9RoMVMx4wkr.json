    {
      "parameters": {
        "jsCode": "const item = $input.first().json.content.parts[0];\nconst input = item.text; // change \"text\" if your field name is different\n\nconst start = \"```json\\n\";\nconst end = \"\\n```\";\n\nlet output = input;\n\nif (input.includes(start)) {\n  output = input;\n\n  if (output.startsWith(start)) {\n    output = output.slice(start.length);\n  }\n\n  if (output.endsWith(end)) {\n    output = output.slice(0, -end.length);\n  }\n}\n\nreturn [\n  {\n    json: {\n      text: output\n    }\n  }\n];"
      },
