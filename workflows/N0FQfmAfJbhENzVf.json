    {
      "parameters": {
        "jsCode": "function extractAssets(urls) {\n  const result = {\n    elementor: [],\n    fonts: []\n  };\n\n  urls.forEach(url => {\n    if (url.includes('elementor')) {\n      result.elementor.push(url);\n    }\n\n    if (url.includes('fonts.googleapis.com')) {\n      result.fonts.push(url);\n    }\n  });\n\n  return result;\n}\n\n// Example usage:\nconst urls = $input.first().json.style\n\nconst extracted = extractAssets(urls);\nreturn {style: extracted}"
