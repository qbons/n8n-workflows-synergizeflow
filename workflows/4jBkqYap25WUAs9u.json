    {
      "parameters": {
        "jsCode": "// 1. Capture the input safely. \n// We join all 'parts' into a single string in case the AI split a leading '\\n' into parts[0]\nconst partsArray = $input.first().json.content.parts || [];\nconst rawData = partsArray.map(p => p.text).join('');\n\nif (!rawData) {\n    throw new Error(\"Could not find the AI output. Check if the field name is correct.\");\n}\n\n// 2. Clean the string\n// This removes markdown backticks and hidden whitespace that often breaks JSON.parse\nconst cleanedString = rawData\n    .replace(/```json/g, '')\n    .replace(/```/g, '')\n    .trim();\n\ntry {\n    // 3. Parse the string into a real object\n    const parsed = JSON.parse(cleanedString);\n    \n    // Return the object so n8n creates separate columns/fields\n    // Note: n8n usually expects an array of items, so we wrap it in [{ json: ... }]\n    return [{ json: parsed }];\n    \n} catch (error) {\n    // If it still fails, return the error and the cleaned string so you can see why\n    return [{\n        json: {\n            error: \"JSON Parse Failed\",\n            message: error.message,\n            debug_string: cleanedString\n        }\n    }];\n}"
      },
