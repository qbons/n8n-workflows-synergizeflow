      "parameters": {
        "jsCode": "// Access the raw description string from your specific node\nconst rawData = $('Get sku data').first().json.description;\n\n// 1. Remove HTML tags (anything between < and >)\n// 2. Replace common HTML entities like &nbsp; and \\n\n// 3. Collapse multiple spaces into one and trim\nconst cleanDescription = rawData\n  .replace(/<[^>]*>/g, ' ') \n  .replace(/&nbsp;/g, ' ')\n  .replace(/\\\\n/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\n// Return only the cleaned string\nreturn {\n  cleanDescription: cleanDescription\n};"
      },
