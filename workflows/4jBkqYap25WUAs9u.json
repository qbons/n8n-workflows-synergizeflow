    {
      "parameters": {
        "jsCode": "// 1. Grab the new images array from your incoming n8n data\n// (Default to an empty array if it doesn't exist so the code doesn't break)\nconst newImages = $input.first().json.images || [];\n\n// 2. Build your productData and merge the arrays\nconst productData = {\n  title: $input.first().json.name,\n  link: $('populate-productData-json').first().json.productData.link,\n  content: $('clean_desc').first().json.cleanDescription,\n  // Use the spread operator (...) to combine both arrays into one!\n  images: [...$('populate-productData-json').first().json.productData.images, ...newImages] \n};\n\n\n\n// 3. Return the final structure\nreturn {\n  json: {\n    productData: productData\n  }\n};"
