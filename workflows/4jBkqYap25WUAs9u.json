    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  // 1. Get the images array from the input (default to an empty array if missing)\n  const sourceImages = $input.first().json.productData.images || [];\n\n  // 2. Map the source images to the new relevantImg structure\n  const relevantImg = sourceImages.map(img => ({\n    desc: img.desc || \"\",\n    url: img.url || \"\"\n  }));\n\n  // 3. Return the nested image.relevantImg object inside the n8n 'json' wrapper\n  return {\n    json: {\n      image: {\n        relevantImg: relevantImg\n      }\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
