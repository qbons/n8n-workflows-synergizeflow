    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\n// 1. Clean up the HTML description (optional but recommended for AI prompts)\n// This removes <p> and <ul> tags to keep the prompt concise\nconst cleanDescription = item.description.replace(/<[^>]*>?/gm, '');\n\n// 2. Format the Arrays as bullet points or comma-separated strings\nconst categories = item.category_names ? item.category_names.join(', ') : 'N/A';\nconst images = item.image_urls ? item.image_urls.map(url => `- ${url}`).join('\\n') : 'No images available';\n\n// 3. Construct the Markdown String\nconst markdown = `\n### Product Details: ${item.name}\n---\n- **SKU:** ${item.sku}\n- **Categories:** ${categories}\n- **Description:** ${cleanDescription.trim()}\n\n**Product Images:**\n${images}\n`.trim();\n\n// 4. Return the markdown as a new property\nreturn {\n  ...item,\n  ai_prompt_markdown: markdown\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
